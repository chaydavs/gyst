": "feedback_test_simulatefeedbackwithconfidence", "callee": "transaction", "source_file": "tests/mcp/feedback.test.ts", "source_location": "L376"}, {"caller_nid": "feedback_test_simulatefeedbackwithconfidence", "callee": "toFixed", "source_file": "tests/mcp/feedback.test.ts", "source_location": "L411"}, {"caller_nid": "feedback_test_simulatefeedbackwithconfidence", "callee": "toFixed", "source_file": "tests/mcp/feedback.test.ts", "source_location": "L411"}]}