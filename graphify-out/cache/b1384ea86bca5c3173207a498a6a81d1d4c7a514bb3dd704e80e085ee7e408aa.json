8"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "warn", "source_file": "src/store/rebuild.ts", "source_location": "L271"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "trim", "source_file": "src/store/rebuild.ts", "source_location": "L277"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "trim", "source_file": "src/store/rebuild.ts", "source_location": "L278"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "isArray", "source_file": "src/store/rebuild.ts", "source_location": "L283"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "filter", "source_file": "src/store/rebuild.ts", "source_location": "L284"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "isArray", "source_file": "src/store/rebuild.ts", "source_location": "L288"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "filter", "source_file": "src/store/rebuild.ts", "source_location": "L289"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "has", "source_file": "src/store/rebuild.ts", "source_location": "L306"}, {"caller_nid": "rebuild_parsemarkdownentry", "callee": "trim", "source_file": "src/store/rebuild.ts", "source_location": "L311"}, {"caller_nid": "rebuild_upsertentry", "callee": "get", "source_file": "src/store/rebuild.ts", "source_location": "L344"}, {"caller_nid": "rebuild_upsertentry", "callee": "query", "source_file": "src/store/rebuild.ts", "source_location": "L344"}, {"caller_nid": "rebuild_upsertentry", "callee": "toISOString", "source_file": "src/store/rebuild.ts", "source_location": "L348"}, {"caller_nid": "rebuild_upsertentry", "callee": "db.transaction(() => {\n      // Use INSERT OR IGNORE to prevent overwriting live DB entries during rebuild.\n      // Existing entries are never modified \u2014 new entries from markdown are inserted only if not present.\n      db.run(\n        `INSERT OR IGNORE INTO entries\n          (id, type, title, content, file_path, error_signature,\n           confidence, source_count, source_tool, created_at, last_confirmed, status, markdown_path)\n         VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n        [\n          entry.id,\n          entry.type,\n          entry.title,\n          entry.content,\n          entry.files[0] ?? entry.relPath,\n          entry.errorSignature ?? null,\n          entry.confidence,\n          entry.sourceCount,\n          entry.sourceTool ?? \"rebuild\",\n          now,\n          entry.lastConfirmed ?? now,\n          entry.status,\n          entry.relPath,\n        ],\n      );\n\n      // Replace file associations\n      db.run(\"DELETE FROM entry_files WHERE entry_id = ?\", [entry.id]);\n      for (const filePath of entry.files) {\n        db.run(\n          \"INSERT OR IGNORE INTO entry_files (entry_id, file_path) VALUES (?, ?)\",\n          [entry.id, filePath],\n        );\n      }\n      // Always record the wiki file itself\n      db.run(\n        \"INSERT OR IGNORE INTO entry_files (entry_id, file_path) VALUES (?, ?)\",\n        [entry.id, entry.relPath],\n      );\n\n      // Replace tag associations\n      db.run(\"DELETE FROM entry_tags WHERE entry_id = ?\", [entry.id]);\n      for (const tag of entry.tags) {\n        db.run(\n          \"INSERT OR IGNORE INTO entry_tags (entry_id, tag) VALUES (?, ?)\",\n          [entry.id, tag],\n        );\n      }\n    })", "source_file": "src/store/rebuild.ts", "source_location": "L351"}, {"caller_nid": "rebuild_upsertentry", "callee": "transaction", "source_file": "src/store/rebuild.ts", "source_location": "L351"}, {"caller_nid": "rebuild_upsertentry", "callee": "String", "source_file": "src/store/rebuild.ts", "source_location": "L400"}, {"caller_nid": "rebuild_upsertentry", "callee": "debug", "source_file": "src/store/rebuild.ts", "source_location": "L404"}, {"caller_nid": "rebuild_extractfirsth1", "callee": "exec", "source_file": "src/store/rebuild.ts", "source_location": "L419"}, {"caller_nid": "rebuild_extractfirsth1", "callee": "trim", "source_file": "src/store