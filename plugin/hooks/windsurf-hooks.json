{
  "_note": "Reference only — installHooksForDetectedTools writes this with absolute paths to ~/.codeium/windsurf/hooks.json",
  "hooks": {
    "pre_session":    [{"command": "node <SCRIPTS_DIR>/session-start.js"}],
