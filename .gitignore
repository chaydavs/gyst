# Test-generated wiki artifacts (convention detector outputs with hash suffixes)
# See memory/feedback_ship_cleanup.md — tests write real markdown into gyst-wiki/
# and the 8-char hash suffix uniquely identifies the generated files.
gyst-wiki/**/*-[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].md

# Generated wiki — the whole tree is regenerated from SQLite via `gyst export`.
# SQLite is the source of truth (see CLAUDE.md Architecture Rules).
gyst-wiki/

# LongMemEval dataset (277MB — re-downloaded by run.ts)
tests/benchmark/longmemeval/data/

# CoIR Python venv (re-created by pip install -r requirements.txt)
tests/benchmark/coir-env/
tests/benchmark/coir/run.log
tests/benchmark/coir/results/

# Claude memory (except template)
.claude/memory/*.md
!.claude/memory/MEMORY.md.template
.worktrees/

# Agent worktree pointer files (they're live filesystem pointers, never code)
.claude/worktrees/

# Graphify structural graph output (derived — regenerate with `graphify`)
graphify-out/

# Dashboard UI build output (built by npm run build:dashboard, ships in npm package)
src/dashboard/dist/

# Dashboard UI dependencies
src/dashboard/ui/node_modules/
.superpowers/
